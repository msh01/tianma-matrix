---
import { getCollection } from "astro:content";
import BookwormLayout from "@tianma/ui-components/BookwormLayout.astro";
import { getArticleViews } from "../lib/views";
import "../styles/global.css";

const articles = (await getCollection("articles"))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .map((article) => ({
    title: article.data.title,
    description: article.data.description,
    tag: article.data.tag,
    url: `/articles/${article.slug}/`,
    date: article.data.publishedAt.toISOString().slice(0, 10),
    views: getArticleViews(article.slug).toLocaleString("zh-CN")
  }));
---

<BookwormLayout
  title="搜索 | 天马 IT 技术笔记"
  description="搜索天马 IT 技术笔记中的文章。"
  canonical="https://it.tianma.example/search/"
>
  <section class="mx-auto max-w-4xl px-5 py-14">
    <h1 class="text-4xl font-bold text-[#152035]">搜索文章</h1>
    <input
      id="search-input"
      class="mt-8 w-full rounded-lg border border-[#D5D5D5] px-5 py-4 text-lg text-[#152035] outline-none transition focus:border-[#01AD9F]"
      type="search"
      placeholder="输入关键词、分类或标题"
      autocomplete="off"
    />
    <div id="search-results" class="mt-10 space-y-6"></div>
  </section>

  <script is:inline define:vars={{ articles }}>
    const input = document.querySelector("#search-input");
    const results = document.querySelector("#search-results");

    function render(items) {
      results.innerHTML = items
        .map(
          (item) => `
            <article class="border-b border-[#D5D5D5] pb-6">
              <p class="text-sm font-semibold text-[#01AD9F]">${item.tag} · ${item.date} · ${item.views} 浏览</p>
              <h2 class="mt-2 text-2xl font-bold text-[#152035]">
                <a class="transition hover:text-[#01AD9F]" href="${item.url}">${item.title}</a>
              </h2>
              <p class="mt-3 leading-7 text-[#747577]">${item.description}</p>
            </article>
          `
        )
        .join("");
    }

    render(articles);
    input.addEventListener("input", () => {
      const keyword = input.value.trim().toLowerCase();
      const filtered = keyword
        ? articles.filter((item) =>
            [item.title, item.description, item.tag].join(" ").toLowerCase().includes(keyword)
          )
        : articles;
      render(filtered);
    });
  </script>
</BookwormLayout>
