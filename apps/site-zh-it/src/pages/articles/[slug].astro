---
import { getCollection, render } from "astro:content";
import OfficialBlogLayout from "@tianma/ui-components/OfficialBlogLayout.astro";
import "../../styles/global.css";

export async function getStaticPaths() {
  const articles = await getCollection("articles");

  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article }
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const publishedDate = article.data.publishedAt.toISOString().slice(0, 10);
---

<OfficialBlogLayout
  title={`${article.data.title} | 天马 IT 技术笔记`}
  description={article.data.description}
  canonical={`https://it.tianma.example/articles/${article.slug}/`}
  siteName="天马 IT 技术笔记"
  navItems={[{ label: "首页", href: "/" }]}
>
  <article class="mx-auto max-w-3xl">
    <a class="text-sm font-semibold text-zinc-500 transition hover:text-zinc-950" href="/">返回文章列表</a>
    <header class="mt-6 border-b border-ink-100 pb-8">
      <p class="text-sm font-semibold text-zinc-500">{article.data.tag}</p>
      <h1 class="mt-3 text-4xl font-bold leading-tight text-ink-900">{article.data.title}</h1>
      <p class="mt-4 leading-8 text-ink-700">{article.data.description}</p>
      <div class="mt-5 flex flex-wrap gap-3 text-sm text-ink-700">
        <time datetime={article.data.publishedAt.toISOString()}>{publishedDate}</time>
        <span>{article.data.readingTime}</span>
      </div>
    </header>

    <div class="article-body mt-8">
      <Content />
    </div>
  </article>
</OfficialBlogLayout>

<style is:global>
  .article-body {
    color: #333946;
    line-height: 1.9;
    font-size: 1rem;
  }

  .article-body p {
    margin: 1.1rem 0;
  }

  .article-body h2 {
    margin: 2rem 0 0.8rem;
    color: #111827;
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.35;
  }

  .article-body code {
    border-radius: 0.25rem;
    background: #eceef0;
    padding: 0.1rem 0.3rem;
    color: #111827;
    font-size: 0.9em;
  }
</style>
