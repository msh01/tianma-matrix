---
import { getCollection, render } from "astro:content";
import ForumLayout from "@tianma/ui-components/ForumLayout.astro";
import {
  formatViews,
  getActivityLabel,
  getArticleViews,
  getParticipants,
  getReplyCount
} from "../../lib/views";
import "../../styles/global.css";

export async function getStaticPaths() {
  const articles = await getCollection("articles");

  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article }
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const publishedDate = article.data.publishedAt.toISOString().slice(0, 10);
const allArticles = (await getCollection("articles"))
  .filter((item) => item.slug !== article.slug)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const similarArticles = allArticles.filter((item) => item.data.tag === article.data.tag).slice(0, 2);
const fallbackArticles = allArticles.slice(0, 2);
const relatedArticles = similarArticles.length ? similarArticles : fallbackArticles;
const views = getArticleViews(article.slug);
const replies = getReplyCount(article.slug);
const participants = getParticipants(article.slug);
---

<ForumLayout
  title={`${article.data.title} | 天马 IT 技术笔记`}
  description={article.data.description}
  canonical={`https://it.tianma.example/articles/${article.slug}/`}
  siteName="TIANMA DEV"
>
  <article class="mx-auto max-w-[980px] py-8">
    <a class="text-sm font-semibold text-[#0088cc] transition hover:text-[#222]" href="/">← 返回话题列表</a>
    <header class="mt-6 border-b border-[#e5e5e5] pb-5">
      <h1 class="text-3xl font-semibold leading-tight text-[#222] md:text-4xl">{article.data.title}</h1>
      <div class="mt-4 flex flex-wrap items-center gap-3 text-sm text-[#777]">
        <a class="bg-[#eee] px-2 py-0.5 text-[#666]" href={`/categories/${article.data.tag}/`}>{article.data.tag}</a>
        <time datetime={article.data.publishedAt.toISOString()}>{publishedDate}</time>
        <span>{article.data.readingTime}</span>
        <span>{formatViews(views)} 浏览</span>
        <span>{replies} 回复</span>
        <span>最后活动 {getActivityLabel(article.slug)}</span>
      </div>
    </header>

    <div class="mt-8 grid gap-5 md:grid-cols-[52px_1fr]">
      <div class="flex h-11 w-11 items-center justify-center rounded-full bg-[#111827] font-bold text-white">天</div>
      <div class="min-w-0 border-b border-[#eee] pb-8">
        <div class="mb-4 flex items-center gap-2 text-sm text-[#777]">
          <span class="font-semibold text-[#222]">天马</span>
          <span>楼主</span>
          <span>{publishedDate}</span>
        </div>
        <p class="mb-6 rounded bg-[#d7f1fc] px-4 py-3 leading-7 text-[#333]">{article.data.description}</p>
        <div class="article-body">
          <Content />
        </div>
      </div>
    </div>

    <aside class="mt-8 flex flex-wrap items-center gap-3 border-y border-[#eee] py-5">
      <span class="font-semibold text-[#222]">参与者：</span>
      {participants.map((name, index) => (
        <span class="flex h-8 w-8 items-center justify-center rounded-full text-xs font-bold text-white" style={`background:${["#a16207", "#64748b", "#111827", "#16a34a", "#e11d48"][index]}`}>{name}</span>
      ))}
      <span class="ml-auto text-sm text-[#777]">{replies} 条回复 · {formatViews(views)} 次浏览</span>
    </aside>
  </article>

  <section class="mx-auto max-w-[980px] pb-16">
    <h2 class="mb-5 text-xl font-semibold text-[#222]">相关话题</h2>
    <div class="space-y-3">
      {relatedArticles.map((item) => (
        <article class="grid grid-cols-[1fr_72px_90px] gap-4 border-b border-[#eee] py-3">
          <h3 class="truncate text-lg text-[#222]">
            <a class="hover:text-[#0088cc]" href={`/articles/${item.slug}/`}>{item.data.title}</a>
          </h3>
          <span class="text-right font-semibold text-[#9a6a3a]">{getReplyCount(item.slug)}</span>
          <span class="text-right text-[#999]">{formatViews(getArticleViews(item.slug))}</span>
        </article>
      ))}
    </div>
  </section>
</ForumLayout>

<style is:global>
  .article-body {
    color: #333;
    line-height: 1.9;
    font-size: 1.05rem;
  }

  .article-body p {
    margin: 1.1rem 0;
  }

  .article-body h2 {
    margin: 2.2rem 0 0.9rem;
    color: #222;
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.35;
  }

  .article-body code {
    border-radius: 0.25rem;
    background: #f3f4f6;
    padding: 0.1rem 0.3rem;
    color: #222;
    font-size: 0.9em;
  }
</style>
