---
import { getCollection, render } from "astro:content";
import BookwormLayout from "@tianma/ui-components/BookwormLayout.astro";
import { formatViews, getArticleViews } from "../../lib/views";
import "../../styles/global.css";

export async function getStaticPaths() {
  const articles = await getCollection("articles");

  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article }
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const publishedDate = article.data.publishedAt.toISOString().slice(0, 10);
const allArticles = (await getCollection("articles"))
  .filter((item) => item.slug !== article.slug)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const similarArticles = allArticles.filter((item) => item.data.tag === article.data.tag).slice(0, 2);
const fallbackArticles = allArticles.slice(0, 2);
const relatedArticles = similarArticles.length ? similarArticles : fallbackArticles;
const views = getArticleViews(article.slug);
---

<BookwormLayout
  title={`${article.data.title} | 天马 IT 技术笔记`}
  description={article.data.description}
  canonical={`https://it.tianma.example/articles/${article.slug}/`}
  siteName="天马 IT 技术笔记"
>
  <article class="mx-auto max-w-4xl px-5 py-14">
    <a class="text-sm font-bold text-[#01AD9F] transition hover:text-[#152035]" href="/">返回文章列表</a>
    <header class="mt-8 text-center">
      <a class="text-sm font-bold uppercase tracking-[0.18em] text-[#01AD9F]" href={`/categories/${article.data.tag}/`}>
        {article.data.tag}
      </a>
      <h1 class="mx-auto mt-4 max-w-3xl text-4xl font-bold leading-tight text-[#152035] md:text-5xl">{article.data.title}</h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg leading-8 text-[#747577]">{article.data.description}</p>
      <div class="mt-6 flex flex-wrap justify-center gap-4 text-sm font-semibold text-[#747577]">
        <span>天马</span>
        <time datetime={article.data.publishedAt.toISOString()}>{publishedDate}</time>
        <span>{article.data.readingTime}</span>
        <span>{formatViews(views)} 浏览</span>
      </div>
    </header>

    <div class="article-body mx-auto mt-12 max-w-3xl border-t border-[#D5D5D5] pt-10">
      <Content />
    </div>

    <aside class="mx-auto mt-12 flex max-w-3xl flex-wrap items-center gap-3 border-y border-[#D5D5D5] py-5">
      <span class="font-bold text-[#152035]">分享：</span>
      <a class="rounded border border-[#D5D5D5] px-3 py-2 text-sm font-semibold text-[#152035] transition hover:border-[#01AD9F] hover:text-[#01AD9F]" href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(article.data.title)}&url=${encodeURIComponent(Astro.url.href)}`}>X</a>
      <a class="rounded border border-[#D5D5D5] px-3 py-2 text-sm font-semibold text-[#152035] transition hover:border-[#01AD9F] hover:text-[#01AD9F]" href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`}>LinkedIn</a>
    </aside>
  </article>

  <section class="mx-auto max-w-6xl px-5 pb-16">
    <h2 class="mb-8 text-3xl font-bold text-[#152035]">相似文章</h2>
    <div class="grid gap-8 sm:grid-cols-2">
      {relatedArticles.map((item) => (
        <article class="rounded-lg border border-[#D5D5D5] p-6 transition hover:border-[#01AD9F]">
          <p class="text-sm font-semibold text-[#01AD9F]">{item.data.tag}</p>
          <p class="mt-2 text-sm font-semibold text-[#747577]">{formatViews(getArticleViews(item.slug))} 浏览</p>
          <h3 class="mt-3 text-2xl font-bold leading-tight text-[#152035]">
            <a class="transition hover:text-[#01AD9F]" href={`/articles/${item.slug}/`}>{item.data.title}</a>
          </h3>
          <p class="mt-3 line-clamp-2 leading-7">{item.data.description}</p>
        </article>
      ))}
    </div>
  </section>
</BookwormLayout>

<style is:global>
  .article-body {
    color: #3f4652;
    line-height: 1.9;
    font-size: 1.05rem;
  }

  .article-body p {
    margin: 1.1rem 0;
  }

  .article-body h2 {
    margin: 2.2rem 0 0.9rem;
    color: #152035;
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.35;
  }

  .article-body code {
    border-radius: 0.25rem;
    background: #f2f7f6;
    padding: 0.1rem 0.3rem;
    color: #152035;
    font-size: 0.9em;
  }
</style>
