---
import { getCollection } from "astro:content";
import ForumLayout from "@tianma/ui-components/ForumLayout.astro";
import "../../styles/global.css";

const articles = await getCollection("articles");
const categories = [...new Set(articles.map((article) => article.data.tag))]
  .sort()
  .map((tag) => ({
    tag,
    count: articles.filter((article) => article.data.tag === tag).length
  }));
---

<ForumLayout
  title="分类 | 天马 IT 技术笔记"
  description="按主题浏览天马 IT 技术笔记的工程文章。"
  canonical="https://it.tianma.example/categories/"
  siteName="TIANMA DEV"
>
  <section class="mx-auto max-w-[980px] py-8">
    <h1 class="text-3xl font-semibold text-[#222]">所有分类</h1>
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {categories.map((category) => (
        <a class="rounded border border-[#e5e5e5] p-5 transition hover:border-[#0088cc] hover:bg-[#f8fbfd]" href={`/categories/${category.tag}/`}>
          <span class="text-xl font-semibold text-[#222]">{category.tag}</span>
          <span class="mt-3 block text-[#747577]">{category.count} 篇文章</span>
        </a>
      ))}
    </div>
  </section>
</ForumLayout>
