---
import { getCollection } from "astro:content";
import BookwormLayout from "@tianma/ui-components/BookwormLayout.astro";
import "../../styles/global.css";

const articles = await getCollection("articles");
const categories = [...new Set(articles.map((article) => article.data.tag))]
  .sort()
  .map((tag) => ({
    tag,
    count: articles.filter((article) => article.data.tag === tag).length
  }));
---

<BookwormLayout
  title="分类 | 天马 IT 技术笔记"
  description="按主题浏览天马 IT 技术笔记的工程文章。"
  canonical="https://it.tianma.example/categories/"
>
  <section class="mx-auto max-w-6xl px-5 py-14">
    <h1 class="text-4xl font-bold text-[#152035]">分类</h1>
    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {categories.map((category) => (
        <a class="rounded-lg border border-[#D5D5D5] p-6 transition hover:border-[#01AD9F]" href={`/categories/${category.tag}/`}>
          <span class="text-2xl font-bold text-[#152035]">{category.tag}</span>
          <span class="mt-3 block text-[#747577]">{category.count} 篇文章</span>
        </a>
      ))}
    </div>
  </section>
</BookwormLayout>
