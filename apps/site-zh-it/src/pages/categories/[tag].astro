---
import { getCollection } from "astro:content";
import BookwormLayout from "@tianma/ui-components/BookwormLayout.astro";
import { formatViews, getArticleViews } from "../../lib/views";
import "../../styles/global.css";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  const tags = [...new Set(articles.map((article) => article.data.tag))];

  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      articles: articles
        .filter((article) => article.data.tag === tag)
        .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
    }
  }));
}

const { tag, articles } = Astro.props;
---

<BookwormLayout
  title={`${tag} 分类 | 天马 IT 技术笔记`}
  description={`浏览 ${tag} 分类下的技术文章。`}
  canonical={`https://it.tianma.example/categories/${tag}/`}
>
  <section class="mx-auto max-w-6xl px-5 py-14">
    <p class="text-sm font-bold uppercase tracking-[0.18em] text-[#01AD9F]">Category</p>
    <h1 class="mt-4 text-4xl font-bold text-[#152035]">{tag}</h1>
    <div class="mt-10 grid gap-8 sm:grid-cols-2">
      {articles.map((article) => (
        <article class="rounded-lg border border-[#D5D5D5] p-6 transition hover:border-[#01AD9F]">
          <div class="flex flex-wrap gap-3 text-sm font-semibold text-[#747577]">
            <time datetime={article.data.publishedAt.toISOString()}>
              {article.data.publishedAt.toISOString().slice(0, 10)}
            </time>
            <span>{formatViews(getArticleViews(article.slug))} 浏览</span>
          </div>
          <h2 class="mt-3 text-2xl font-bold leading-tight text-[#152035]">
            <a class="transition hover:text-[#01AD9F]" href={`/articles/${article.slug}/`}>{article.data.title}</a>
          </h2>
          <p class="mt-3 line-clamp-2 leading-7">{article.data.description}</p>
        </article>
      ))}
    </div>
  </section>
</BookwormLayout>
