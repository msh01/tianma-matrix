---
import { getCollection } from "astro:content";
import ForumLayout from "@tianma/ui-components/ForumLayout.astro";
import { formatViews, getActivityLabel, getArticleViews, getReplyCount } from "../../lib/views";
import "../../styles/global.css";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  const tags = [...new Set(articles.map((article) => article.data.tag))];

  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      articles: articles
        .filter((article) => article.data.tag === tag)
        .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
    }
  }));
}

const { tag, articles } = Astro.props;
---

<ForumLayout
  title={`${tag} 分类 | 天马 IT 技术笔记`}
  description={`浏览 ${tag} 分类下的技术文章。`}
  canonical={`https://it.tianma.example/categories/${tag}/`}
  siteName="TIANMA DEV"
>
  <section class="mx-auto max-w-[980px] py-8">
    <p class="text-sm font-semibold text-[#0088cc]">Category</p>
    <h1 class="mt-2 text-3xl font-semibold text-[#222]">{tag}</h1>
    <div class="mt-8 border-t border-[#e5e5e5]">
      {articles.map((article) => (
        <article class="grid grid-cols-[1fr_80px_92px_86px] gap-4 border-b border-[#eee] py-4">
          <div class="min-w-0">
            <h2 class="truncate text-xl font-medium text-[#222]">
              <a class="hover:text-[#0088cc]" href={`/articles/${article.slug}/`}>{article.data.title}</a>
            </h2>
            <p class="mt-2 line-clamp-2 text-[#666]">{article.data.description}</p>
          </div>
          <div class="text-right font-bold text-[#9a6a3a]">{getReplyCount(article.slug)}</div>
          <div class="text-right font-bold text-[#ff6a00]">{formatViews(getArticleViews(article.slug))}</div>
          <div class="text-right text-[#999]">{getActivityLabel(article.slug)}</div>
          <div class="hidden">
            <time datetime={article.data.publishedAt.toISOString()}>
              {article.data.publishedAt.toISOString().slice(0, 10)}
            </time>
          </div>
        </article>
      ))}
    </div>
  </section>
</ForumLayout>
