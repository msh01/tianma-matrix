---
import BaseLayout from "@tianma/ui-components/BaseLayout.astro";
import "../styles/global.css";

const articles = [
  { title: "Astro SSG 内容站架构笔记", tag: "Frontend", date: "2026-05-06" },
  { title: "Turborepo 在多站点矩阵中的缓存策略", tag: "Build", date: "2026-05-05" },
  { title: "TypeScript 工程化配置的最小闭环", tag: "TypeScript", date: "2026-05-04" }
];
---

<BaseLayout
  title="天马 IT 技术笔记 | 软件开发与工程实践"
  description="一个干净的中文技术博客，只展示软件开发、前端架构和工程实践内容。"
  canonical="https://it.tianma.example/"
  siteName="天马 IT 技术笔记"
>
  <section class="max-w-3xl">
    <p class="text-sm font-semibold text-brand-600">Engineering Notes</p>
    <h1 class="mt-3 text-4xl font-bold leading-tight">干净、克制、专注内容的技术博客</h1>
    <p class="mt-4 leading-8 text-ink-700">
      这个站点不放广告，也不做引流，只沉淀 IT、软件开发、前端架构和工程化文章。
    </p>
  </section>

  <section class="mt-10 divide-y divide-ink-100 rounded-lg border border-ink-100 bg-white">
    {
      articles.map((article) => (
        <article class="grid gap-2 p-5 sm:grid-cols-[1fr_auto] sm:items-center">
          <div>
            <h2 class="text-xl font-semibold">{article.title}</h2>
            <p class="mt-2 text-sm text-ink-700">{article.tag}</p>
          </div>
          <time class="text-sm text-ink-700" datetime={article.date}>{article.date}</time>
        </article>
      ))
    }
  </section>
</BaseLayout>
