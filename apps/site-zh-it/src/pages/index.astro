---
import { getCollection } from "astro:content";
import OfficialBlogLayout from "@tianma/ui-components/OfficialBlogLayout.astro";
import "../styles/global.css";

const articles = (await getCollection("articles")).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
---

<OfficialBlogLayout
  title="天马 IT 技术笔记 | 软件开发与工程实践"
  description="一个干净的中文技术博客，只展示软件开发、前端架构和工程实践内容。"
  canonical="https://it.tianma.example/"
  siteName="天马 IT 技术笔记"
  tagline="一个无广告、无引流的工程写作空间，记录软件开发、前端架构、构建系统和内容站工程化。"
  navItems={[{ label: "首页", href: "/" }]}
>
  <section class="space-y-8">
    {
      articles.map((article) => (
        <article class="border-b border-zinc-200 pb-8 last:border-0">
          <div class="flex flex-wrap items-center gap-3 text-sm text-zinc-500">
            <time datetime={article.data.publishedAt.toISOString()}>
              {article.data.publishedAt.toISOString().slice(0, 10)}
            </time>
            <span>{article.data.tag}</span>
            <span>{article.data.readingTime}</span>
          </div>
          <h2 class="mt-3 text-2xl font-bold tracking-tight">
            <a class="transition hover:text-brand-600" href={`/articles/${article.slug}/`}>
                {article.data.title}
            </a>
          </h2>
          <p class="mt-3 leading-7 text-zinc-600">{article.data.description}</p>
        </article>
      ))
    }
  </section>
</OfficialBlogLayout>
