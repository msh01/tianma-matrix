---
import { getCollection } from "astro:content";
import ForumLayout from "@tianma/ui-components/ForumLayout.astro";
import {
  formatViews,
  getArticleViews,
  getParticipants,
  getReplyCount
} from "../lib/views";
import "../styles/global.css";

const articles = (await getCollection("articles")).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

const tagIcon: Record<string, string> = {
  Architecture: "●",
  Build: "◆",
  Content: "■",
  Frontend: "⌁",
  Process: "✚",
  SEO: "◌",
  TypeScript: "▤"
};
---

<ForumLayout
  title="天马 IT 技术笔记 | 软件开发与工程实践"
  description="一个干净的中文技术博客，只展示软件开发、前端架构和工程实践内容。"
  canonical="https://it.tianma.example/"
  siteName="TIANMA DEV"
>
  <section class="mx-auto max-w-[1180px]">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="text-4xl font-bold tracking-tight text-[#222] md:text-5xl">Where technical practice begins</h1>
      <form class="mt-6 flex h-12 items-center rounded border border-[#cfcfcf] bg-white px-4" action="/search/">
        <span class="mr-3 text-xl text-[#777]">⌕</span>
        <input class="w-full border-0 bg-transparent text-base outline-none" name="q" placeholder="搜索" />
        <span class="text-xl text-[#999]">☷</span>
      </form>
    </div>

    <div class="mt-12 bg-[#d7f1fc] px-5 py-3 text-[#222]">
      <strong>真诚、友善、团结、专业</strong>，共建工程实践与软件开发讨论社区。<a class="text-[#0088cc]" href="/categories/">《社区规则》</a>
    </div>

    <div class="mt-4 flex flex-wrap items-center gap-2">
      <a class="rounded border border-[#cfcfcf] px-3 py-2 text-[#666]" href="/categories/">类别 ›</a>
      <a class="rounded border border-[#cfcfcf] px-3 py-2 text-[#666]" href="/search/">标签 ›</a>
      <nav class="ml-2 flex gap-8 text-[#222]">
        <a class="border-b-2 border-[#0088cc] px-2 py-2 font-semibold text-[#0088cc]" href="/">最新</a>
        <a class="px-2 py-2" href="/">排行榜</a>
        <a class="px-2 py-2" href="/">热门</a>
        <a class="px-2 py-2" href="/categories/">类别</a>
      </nav>
    </div>

    <div class="mt-3 grid grid-cols-[1fr_150px_80px_92px_104px] border-b border-[#e5e5e5] px-3 py-3 text-[#999] max-xl:grid-cols-[1fr_80px_92px_104px]">
      <span>话题</span>
      <span class="hidden xl:block"></span>
      <span class="text-right">回复</span>
      <span class="text-right">浏览量</span>
      <span class="text-right">发布时间</span>
    </div>

    <section>
      {articles.map((article, index) => (
        <article class="grid grid-cols-[1fr_150px_80px_92px_104px] gap-4 border-b border-[#eee] px-3 py-4 max-xl:grid-cols-[1fr_80px_92px_104px]">
          <div class="min-w-0">
            <h2 class="truncate text-xl font-medium text-[#222]">
              <a class="hover:text-[#0088cc]" href={`/articles/${article.slug}/`}>
                {index < 3 ? "⚑ " : ""}{article.data.title}
              </a>
            </h2>
            <div class="mt-1 flex flex-wrap items-center gap-2 text-sm text-[#777]">
              <span>运营反馈</span>
              <a class="inline-flex items-center gap-1 bg-[#eee] px-2 py-0.5 text-[#666]" href={`/categories/${article.data.tag}/`}>
                <span>{tagIcon[article.data.tag] ?? "●"}</span>{article.data.tag}
              </a>
              <span class="bg-[#eee] px-2 py-0.5">公告</span>
            </div>
            <p class="mt-2 line-clamp-2 leading-6 text-[#666]">{article.data.description} ... 阅读更多</p>
          </div>
          <div class="hidden items-center justify-end gap-1 xl:flex">
            {getParticipants(article.slug).map((name, avatarIndex) => (
              <span class="flex h-6 w-6 items-center justify-center rounded-full text-xs font-bold text-white" style={`background:${["#a16207", "#64748b", "#111827", "#16a34a", "#e11d48"][avatarIndex]}`}>
                {name}
              </span>
            ))}
          </div>
          <div class="text-right font-bold text-[#9a6a3a]">{getReplyCount(article.slug)}</div>
          <div class="text-right font-bold text-[#ff6a00]">{formatViews(getArticleViews(article.slug))}</div>
          <time class="text-right text-[#999]" datetime={article.data.publishedAt.toISOString()}>
            {article.data.publishedAt.toISOString().slice(0, 10)}
          </time>
        </article>
      ))}
    </section>
  </section>
</ForumLayout>
