---
import { getCollection } from "astro:content";
import BookwormLayout from "@tianma/ui-components/BookwormLayout.astro";
import { formatViews, getArticleViews } from "../lib/views";
import "../styles/global.css";

const articles = (await getCollection("articles")).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

const [featured, ...restArticles] = articles;
const categories = [...new Set(articles.map((article) => article.data.tag))].sort();

const coverClassByTag: Record<string, string> = {
  Architecture: "from-[#dff7f4] via-[#f7fbfa] to-[#f1f6ff]",
  Build: "from-[#fff1d7] via-[#fffaf1] to-[#eaf7f4]",
  Content: "from-[#f3f1ff] via-[#fbfaff] to-[#eaf7f4]",
  Frontend: "from-[#dff7f4] via-[#f7fbfa] to-[#fef7ed]",
  Process: "from-[#eef2ff] via-[#ffffff] to-[#f4f4f5]",
  SEO: "from-[#ecfeff] via-[#ffffff] to-[#fef3c7]",
  TypeScript: "from-[#e0f2fe] via-[#ffffff] to-[#ecfdf5]"
};

const getCoverClass = (tag: string) => coverClassByTag[tag] ?? "from-[#f7f7f8] via-white to-[#eaf7f4]";
---

<BookwormLayout
  title="天马 IT 技术笔记 | 软件开发与工程实践"
  description="一个干净的中文技术博客，只展示软件开发、前端架构和工程实践内容。"
  canonical="https://it.tianma.example/"
  siteName="天马 IT 技术笔记"
>
  <section class="mx-auto max-w-6xl px-5 py-14">
    <div class="mb-12 max-w-3xl">
      <p class="text-sm font-bold uppercase tracking-[0.2em] text-[#01AD9F]">Engineering Journal</p>
      <h1 class="mt-4 text-4xl font-bold leading-tight text-[#152035] md:text-5xl">
        软件开发、前端架构和内容站工程化笔记
      </h1>
      <p class="mt-5 text-lg leading-8 text-[#747577]">
        使用 Bookworm Light Astro 的阅读优先博客风格：清爽列表、分类入口、作者元信息和更适合长文阅读的文章页。
      </p>
    </div>

    {
      featured && (
        <article class="mb-16 grid gap-8 md:grid-cols-[1.1fr_0.9fr] md:items-center">
          <a
            href={`/articles/${featured.slug}/`}
            class={`group flex min-h-80 items-center justify-center overflow-hidden rounded-lg bg-gradient-to-br ${getCoverClass(featured.data.tag)} p-8`}
          >
            <div class="max-w-sm text-center">
              <p class="text-sm font-bold uppercase tracking-[0.18em] text-[#01AD9F]">{featured.data.tag}</p>
              <p class="mt-5 text-3xl font-bold leading-tight text-[#152035] transition group-hover:text-[#01AD9F]">
                {featured.data.title}
              </p>
            </div>
          </a>
          <div>
            <ul class="mb-4 flex flex-wrap items-center gap-4 text-sm font-semibold text-[#747577]">
              <li>天马</li>
              <li>
                <time datetime={featured.data.publishedAt.toISOString()}>
                  {featured.data.publishedAt.toISOString().slice(0, 10)}
                </time>
              </li>
              <li>
                <a class="hover:text-[#01AD9F]" href={`/categories/${featured.data.tag}/`}>{featured.data.tag}</a>
              </li>
              <li>{formatViews(getArticleViews(featured.slug))} 浏览</li>
            </ul>
            <h2 class="text-3xl font-bold leading-tight text-[#152035]">
              <a class="transition hover:text-[#01AD9F]" href={`/articles/${featured.slug}/`}>
                {featured.data.title}
              </a>
            </h2>
            <p class="mt-4 text-lg leading-8">{featured.data.description}</p>
            <a class="mt-6 inline-flex rounded border border-[#01AD9F] px-5 py-3 font-bold text-[#01AD9F] transition hover:bg-[#01AD9F] hover:text-white" href={`/articles/${featured.slug}/`}>
              阅读文章
            </a>
          </div>
        </article>
      )
    }

    <div class="mb-10 flex flex-wrap gap-3">
      {categories.map((category) => (
        <a class="rounded-full border border-[#D5D5D5] px-4 py-2 text-sm font-semibold text-[#152035] transition hover:border-[#01AD9F] hover:text-[#01AD9F]" href={`/categories/${category}/`}>
          {category}
        </a>
      ))}
    </div>

    <section class="grid gap-x-8 gap-y-12 sm:grid-cols-2">
    {
      restArticles.map((article) => (
        <article>
          <a
            href={`/articles/${article.slug}/`}
            class={`group mb-6 flex min-h-56 items-center justify-center overflow-hidden rounded-lg bg-gradient-to-br ${getCoverClass(article.data.tag)} p-6`}
          >
            <span class="max-w-xs text-center text-2xl font-bold leading-tight text-[#152035] transition group-hover:text-[#01AD9F]">
              {article.data.title}
            </span>
          </a>
          <ul class="mb-4 flex flex-wrap items-center gap-4 text-sm font-semibold text-[#747577]">
            <li>天马</li>
            <li>
              <time datetime={article.data.publishedAt.toISOString()}>
                {article.data.publishedAt.toISOString().slice(0, 10)}
              </time>
            </li>
            <li>
              <a class="hover:text-[#01AD9F]" href={`/categories/${article.data.tag}/`}>{article.data.tag}</a>
            </li>
            <li>{formatViews(getArticleViews(article.slug))} 浏览</li>
          </ul>
          <h2 class="mb-4 text-2xl font-bold leading-tight text-[#152035]">
            <a class="transition hover:text-[#01AD9F]" href={`/articles/${article.slug}/`}>
              {article.data.title}
            </a>
          </h2>
          <p class="line-clamp-2 leading-7">{article.data.description}</p>
        </article>
      ))
    }
    </section>
  </section>
</BookwormLayout>
