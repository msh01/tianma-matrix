---
import BaseLayout from "@tianma/ui-components/BaseLayout.astro";
import WeChatPromoCard from "@tianma/ui-components/WeChatPromoCard.astro";
import "../styles/global.css";

const posts = [
  "如何用 AI 自动生成一周内容选题",
  "面向个人创作者的 RAG 知识库入门",
  "从提示词到工作流：把 AI 变成内容助理"
];
---

<BaseLayout
  title="天马 AI 实验室 | AI 资讯、教程与自动化工作流"
  description="聚焦 AI 工具、内容自动化和知识管理的中文内容站。"
  canonical="https://ai.tianma.example/"
  siteName="天马 AI 实验室"
>
  <section class="grid gap-8 md:grid-cols-[1.4fr_0.8fr] md:items-start">
    <div>
      <p class="text-sm font-semibold text-brand-600">AI Content Hub</p>
      <h1 class="mt-3 text-4xl font-bold leading-tight text-ink-900">把 AI 工具沉淀成可复用的内容生产力</h1>
      <p class="mt-4 max-w-2xl leading-8 text-ink-700">
        这里用于发布 AI 资讯、教程、工具测评和自动化实践，并在文章末尾承接微信公众号引流。
      </p>
    </div>
    <div class="rounded-lg border border-ink-100 bg-white p-5 shadow-soft">
      <h2 class="text-lg font-semibold">近期文章</h2>
      <ul class="mt-4 space-y-3">
        {posts.map((post) => <li class="border-b border-ink-100 pb-3 text-ink-700 last:border-0">{post}</li>)}
      </ul>
    </div>
  </section>

  <WeChatPromoCard />
</BaseLayout>
