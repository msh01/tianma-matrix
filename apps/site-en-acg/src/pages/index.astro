---
import BaseLayout from "@tianma/ui-components/BaseLayout.astro";
import AdSense from "@tianma/google-ads/AdSense.astro";
import "../styles/global.css";
---

<BaseLayout
  title="Tianma ACG Guide | Anime Culture, Watchlists, and Character Notes"
  description="An English anime and ACG content site prepared for AdSense monetization."
  canonical="https://acg.tianma.example/"
  lang="en"
  siteName="Tianma ACG Guide"
  enableAds={true}
>
  <section class="max-w-3xl">
    <p class="text-sm font-semibold text-brand-600">Anime Content Network</p>
    <h1 class="mt-3 text-4xl font-bold leading-tight">Anime explainers and evergreen ACG guides for global readers</h1>
    <p class="mt-4 leading-8 text-ink-700">
      This SSG site is structured for English SEO articles, evergreen guides, and AdSense-ready content pages.
    </p>
  </section>

  <AdSense class="mt-8" />

  <section class="mt-10 grid gap-4 sm:grid-cols-3">
    {["Seasonal watchlists", "Character guides", "Beginner explainers"].map((item) => (
      <article class="rounded-lg border border-ink-100 bg-white p-5">
        <h2 class="font-semibold">{item}</h2>
        <p class="mt-2 text-sm leading-6 text-ink-700">Static content demo for the ACG vertical.</p>
      </article>
    ))}
  </section>
</BaseLayout>
