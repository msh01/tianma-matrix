---
import BaseLayout from "@tianma/ui-components/BaseLayout.astro";
import AdSense from "@tianma/google-ads/AdSense.astro";
import "../styles/global.css";
---

<BaseLayout
  title="Tianma China Notes | Culture, Travel Basics, and Everyday Knowledge"
  description="An English content site introducing Chinese culture, daily life, customs, and useful background knowledge."
  canonical="https://china.tianma.example/"
  lang="en"
  siteName="Tianma China Notes"
  enableAds={true}
>
  <section class="grid gap-8 md:grid-cols-[1.2fr_0.8fr] md:items-start">
    <div>
      <p class="text-sm font-semibold text-brand-600">China Knowledge Hub</p>
      <h1 class="mt-3 text-4xl font-bold leading-tight">Clear explanations of Chinese culture for curious global readers</h1>
      <p class="mt-4 leading-8 text-ink-700">
        This site is prepared for evergreen English articles on traditions, travel basics, food, language, and modern life in China.
      </p>
    </div>
    <div class="rounded-lg border border-ink-100 bg-white p-5 shadow-soft">
      <h2 class="font-semibold">Content pillars</h2>
      <ul class="mt-4 space-y-3 text-sm text-ink-700">
        <li>Culture and festivals</li>
        <li>Travel and etiquette</li>
        <li>Everyday China explainers</li>
      </ul>
    </div>
  </section>

  <AdSense class="mt-8" />
</BaseLayout>
