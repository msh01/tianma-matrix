---
import { caseStudies, getCaseBySlug } from "../../data/cases";
import PageLayout from "../../layouts/PageLayout.astro";
import "../../styles/global.css";

export function getStaticPaths() {
  return caseStudies.map((item) => ({
    params: { slug: item.slug }
  }));
}

const { slug } = Astro.params;
const caseStudy = getCaseBySlug(slug ?? "");

if (!caseStudy) {
  return Astro.redirect("/");
}
---

<PageLayout title={`${caseStudy.title} | 冰硅网络科技案例`} description={caseStudy.summary}>
  <article class="bg-white">
    <section class="bg-slate-950 px-4 py-20 text-white sm:px-6">
      <div class="mx-auto max-w-5xl">
        <a class="text-sm font-bold text-cyan-300 transition hover:text-cyan-100" href="/#cases">返回案例列表</a>
        <p class="mt-10 text-sm font-bold uppercase tracking-[0.18em] text-cyan-300">{caseStudy.category}</p>
        <h1 class="mt-4 text-4xl font-extrabold tracking-tight md:text-6xl">{caseStudy.title}</h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">{caseStudy.summary}</p>
      </div>
    </section>

    <section class="px-4 py-16 sm:px-6">
      <div class="mx-auto grid max-w-5xl gap-6 lg:grid-cols-[1fr_0.38fr]">
        <div class="space-y-6">
          <section class="rounded-2xl border border-slate-200 bg-white p-7 shadow-sm">
            <h2 class="text-2xl font-extrabold tracking-tight text-slate-950">客户情况</h2>
            <p class="mt-4 leading-8 text-slate-600">{caseStudy.background}</p>
          </section>
          <section class="rounded-2xl border border-slate-200 bg-white p-7 shadow-sm">
            <h2 class="text-2xl font-extrabold tracking-tight text-slate-950">做了哪些功能</h2>
            <div class="mt-5 grid gap-3 sm:grid-cols-2">
              {caseStudy.modules.map((moduleName) => (
                <div class="rounded-xl bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-700 ring-1 ring-slate-200">{moduleName}</div>
              ))}
            </div>
          </section>
          <section class="rounded-2xl border border-slate-200 bg-white p-7 shadow-sm">
            <h2 class="text-2xl font-extrabold tracking-tight text-slate-950">交付取舍</h2>
            <div class="mt-5 space-y-4">
              {caseStudy.delivery.map((item) => (
                <p class="leading-8 text-slate-600">{item}</p>
              ))}
            </div>
          </section>
        </div>

        <aside class="rounded-2xl border border-slate-200 bg-slate-50 p-7">
          <h2 class="text-lg font-extrabold text-slate-950">一句话说明</h2>
          <p class="mt-4 leading-7 text-slate-600">{caseStudy.note}</p>
          <a class="mt-8 inline-flex rounded-full bg-cyan-700 px-5 py-3 text-sm font-bold text-white transition hover:bg-cyan-800" href="/#cases">
            查看更多案例
          </a>
        </aside>
      </div>
    </section>
  </article>
</PageLayout>
