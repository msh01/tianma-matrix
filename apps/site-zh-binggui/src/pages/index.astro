---
import CallToAction from "../components/widgets/CallToAction.astro";
import Content from "../components/widgets/Content.astro";
import FAQs from "../components/widgets/FAQs.astro";
import Features from "../components/widgets/Features.astro";
import Hero from "../components/widgets/Hero.astro";
import Stats from "../components/widgets/Stats.astro";
import Steps from "../components/widgets/Steps.astro";
import PageLayout from "../layouts/PageLayout.astro";
import "../styles/global.css";

const services = [
  {
    title: "定制软件开发",
    description: "面向业务系统、管理后台、门户网站、数据平台和 SaaS 产品，提供从原型到上线的完整交付。",
    icon: "▣"
  },
  {
    title: "小程序与移动端",
    description: "建设微信小程序、H5 和移动端应用，适合会员、预约、门店、内容和交易类业务。",
    icon: "◈"
  },
  {
    title: "系统集成与重构",
    description: "打通 CRM、ERP、支付、消息、工单、报表和第三方接口，也能维护与重构遗留系统。",
    icon: "◇"
  },
  {
    title: "AI 自动化工具",
    description: "把内容生成、客服助理、流程审批和数据分析嵌入现有系统，减少重复操作。",
    icon: "✦"
  }
];

const process = [
  { title: "业务诊断", description: "梳理业务目标、角色流程、数据边界和上线约束。" },
  { title: "原型确认", description: "输出信息架构、页面原型和阶段报价，先确认再开发。" },
  { title: "迭代开发", description: "以可演示版本推进，定期同步进度、风险和取舍。" },
  { title: "测试上线", description: "完成联调、验收、部署和基础监控，保证上线节奏。" },
  { title: "运维增长", description: "持续处理反馈、数据优化、功能迭代和稳定性维护。" }
];

const scenarios = [
  {
    title: "从 0 到 1 新产品",
    description: "适合创业团队、企业新业务和内部创新项目，用最短路径验证核心流程。"
  },
  {
    title: "已有系统持续迭代",
    description: "接手老项目、补齐文档和测试，逐步优化架构，避免一次性大重写。"
  },
  {
    title: "业务数字化补能力",
    description: "把线下流程、Excel 协作和人工流转转成可追踪、可统计、可自动化的系统。"
  }
];

const faqs = [
  {
    title: "没有完整需求文档可以聊吗？",
    description: "可以。初期只需要说清业务目标、主要用户和当前问题，我们会一起把需求拆成可评估范围。"
  },
  {
    title: "项目多久能看到第一个版本？",
    description: "常见业务系统会在 2-4 周内交付首个可演示版本，具体节奏取决于接口、数据和页面复杂度。"
  },
  {
    title: "上线后是否继续维护？",
    description: "支持。可以按月维护，也可以按迭代包合作，覆盖问题修复、功能优化、监控和部署支持。"
  }
];
---

<PageLayout>
  <Hero image={{ src: "/assets/software-delivery-hero.png", alt: "冰硅网络科技软件交付工作台视觉" }}>
    <Fragment slot="title">
      让软件外包更清晰、更可控、更能长期运行
    </Fragment>
    <Fragment slot="subtitle">
      冰硅网络科技用 AstroWind 式的高性能官网呈现服务能力，也用同样的工程习惯交付客户项目：需求清楚、阶段可见、上线稳妥、后续可维护。
    </Fragment>
    <Fragment slot="actions">
      <a class="rounded-full bg-cyan-700 px-6 py-3 text-center text-sm font-bold text-white shadow-soft transition hover:bg-cyan-800" href="#contact">
        获取方案评估
      </a>
      <a class="rounded-full border border-slate-300 bg-white px-6 py-3 text-center text-sm font-bold text-slate-950 transition hover:border-cyan-700 hover:text-cyan-700" href="#features">
        查看服务能力
      </a>
    </Fragment>
  </Hero>

  <Stats
    stats={[
      { title: "核心交付场景", amount: "7+" },
      { title: "首个可用版本", amount: "2-4周" },
      { title: "项目经理跟进", amount: "1对1" }
    ]}
  />

  <Features
    id="features"
    tagline="Services"
    title="像产品团队一样承接外包项目"
    subtitle="参考 AstroWind 的组件化页面结构，把能力拆成清楚的模块，也把项目拆成清楚的交付节点。"
    items={services}
  />

  <Content
    id="solutions"
    tagline="Solutions"
    title="为不同阶段的业务补齐技术能力"
    items={scenarios}
    image={{ src: "/assets/software-delivery-hero.png", alt: "软件外包交付协作场景" }}
    isReversed
  />

  <Steps
    id="process"
    title="把不确定性前置处理"
    subtitle="每个阶段都有明确输出物和确认节点，适合从 0 到 1 的新产品，也适合已有系统的持续迭代。"
    items={process}
  />

  <FAQs id="faq" title="开始合作前，常见问题先说清楚" items={faqs} />

  <CallToAction id="contact">
    <Fragment slot="title">先聊清楚问题，再决定怎么做</Fragment>
    <Fragment slot="subtitle">
      你可以带着一句想法、一份需求文档，或者一个已经跑不动的旧系统来沟通。我们会先给出范围判断、技术路径和阶段预算建议。
    </Fragment>
    <Fragment slot="actions">
      <a class="inline-flex rounded-full bg-white px-6 py-3 text-sm font-bold text-slate-950 transition hover:bg-cyan-100" href="mailto:hello@binggui.example">
        hello@binggui.example
      </a>
    </Fragment>
  </CallToAction>
</PageLayout>
