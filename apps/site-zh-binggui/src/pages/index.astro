---
import CaseGrid from "../components/widgets/CaseGrid.astro";
import Content from "../components/widgets/Content.astro";
import Features from "../components/widgets/Features.astro";
import Hero from "../components/widgets/Hero.astro";
import Stats from "../components/widgets/Stats.astro";
import { caseStudies } from "../data/cases";
import PageLayout from "../layouts/PageLayout.astro";
import "../styles/global.css";

const services = [
  {
    title: "定制软件开发",
    description: "面向业务系统、管理后台、门户网站、数据平台和 SaaS 产品，提供从原型到上线的完整交付。",
    icon: "▣"
  },
  {
    title: "小程序与移动端",
    description: "建设微信小程序、H5 和移动端应用，适合会员、预约、门店、内容和交易类业务。",
    icon: "◈"
  },
  {
    title: "系统集成与重构",
    description: "打通 CRM、ERP、支付、消息、工单、报表和第三方接口，也能维护与重构遗留系统。",
    icon: "◇"
  },
  {
    title: "AI 自动化工具",
    description: "把内容生成、客服助理、流程审批和数据分析嵌入现有系统，减少重复操作。",
    icon: "✦"
  }
];

const scenarios = [
  {
    title: "从 0 到 1 新产品",
    description: "适合创业团队、企业新业务和内部创新项目，用最短路径验证核心流程。"
  },
  {
    title: "已有系统持续迭代",
    description: "接手老项目、补齐文档和测试，逐步优化架构，避免一次性大重写。"
  },
  {
    title: "业务数字化补能力",
    description: "把线下流程、Excel 协作和人工流转转成可追踪、可统计、可自动化的系统。"
  }
];

---

<PageLayout>
  <Hero image={{ src: "/assets/software-delivery-hero.png", alt: "冰硅网络科技软件交付工作台视觉" }}>
    <Fragment slot="title">
      让软件外包更清晰、更可控、更能长期运行
    </Fragment>
    <Fragment slot="subtitle">
      冰硅网络科技用 AstroWind 式的高性能官网呈现服务能力，也用同样的工程习惯交付客户项目：需求清楚、阶段可见、上线稳妥、后续可维护。
    </Fragment>
    <Fragment slot="actions">
      <a class="rounded-full bg-cyan-700 px-6 py-3 text-center text-sm font-bold text-white shadow-soft transition hover:bg-cyan-800" href="#cases">
        查看案例
      </a>
      <a class="rounded-full border border-slate-300 bg-white px-6 py-3 text-center text-sm font-bold text-slate-950 transition hover:border-cyan-700 hover:text-cyan-700" href="#features">
        查看服务能力
      </a>
    </Fragment>
  </Hero>

  <Stats
    stats={[
      { title: "核心交付场景", amount: "7+" },
      { title: "首个可用版本", amount: "2-4周" },
      { title: "项目经理跟进", amount: "1对1" }
    ]}
  />

  <Features
    id="features"
    tagline="Services"
    title="像产品团队一样承接外包项目"
    subtitle="参考 AstroWind 的组件化页面结构，把能力拆成清楚的模块，也把项目拆成清楚的交付节点。"
    items={services}
  />

  <Content
    id="solutions"
    tagline="Solutions"
    title="为不同阶段的业务补齐技术能力"
    items={scenarios}
    image={{ src: "/assets/software-delivery-hero.png", alt: "软件外包交付协作场景" }}
    isReversed
  />

  <CaseGrid
    id="cases"
    title="从真实业务场景看交付方式"
    subtitle="这些案例入口对应独立文章页，展示冰硅网络科技在小程序、企业系统集成和 AI 自动化方向的典型交付路径。"
    items={caseStudies}
  />
</PageLayout>
