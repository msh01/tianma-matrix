---
type Item = {
  title: string;
  description: string;
};

export interface Props {
  id?: string;
  title: string;
  items: Item[];
}

const { id, title, items } = Astro.props;
---

<section id={id} class="bg-slate-50 py-20">
  <div class="mx-auto max-w-5xl px-4 sm:px-6">
    <div class="text-center">
      <p class="text-sm font-bold uppercase tracking-[0.18em] text-cyan-700">FAQ</p>
      <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-slate-950 md:text-4xl">{title}</h2>
    </div>
    <div class="mt-10 grid gap-4">
      {items.map((item) => (
        <article class="rounded-2xl border border-slate-200 bg-white p-6">
          <h3 class="font-bold text-slate-950">{item.title}</h3>
          <p class="mt-3 leading-7 text-slate-600">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
