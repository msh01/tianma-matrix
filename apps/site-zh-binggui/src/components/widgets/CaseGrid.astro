---
import type { CaseStudy } from "../../data/cases";

export interface Props {
  id?: string;
  title: string;
  subtitle?: string;
  items: CaseStudy[];
}

const { id, title, subtitle, items } = Astro.props;
---

<section id={id} class="bg-white py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">
    <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
      <div class="max-w-3xl">
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-cyan-700">Case Studies</p>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-slate-950 md:text-4xl">{title}</h2>
        {subtitle && <p class="mt-5 text-lg leading-8 text-slate-600">{subtitle}</p>}
      </div>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {items.map((item) => (
        <a
          class="group flex overflow-hidden rounded-2xl border border-slate-200 bg-slate-50 shadow-sm transition hover:-translate-y-1 hover:border-cyan-200 hover:bg-white hover:shadow-soft"
          href={`/cases/${item.slug}/`}
        >
          <div class="flex w-full flex-col">
            <div class="aspect-[16/9] overflow-hidden bg-slate-200">
              <img
                class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                src={item.image}
                alt={`${item.title}案例配图`}
                loading="lazy"
              />
            </div>
            <div class="flex flex-1 flex-col p-6">
              <div class="flex items-center justify-between gap-3">
                <span class="rounded-full bg-cyan-100 px-3 py-1 text-xs font-bold text-cyan-800">{item.category}</span>
                <span class="text-sm font-bold text-slate-400 transition group-hover:text-cyan-700">查看案例</span>
              </div>
              <h3 class="mt-7 text-2xl font-extrabold tracking-tight text-slate-950">{item.title}</h3>
              <p class="mt-4 flex-1 text-sm leading-7 text-slate-600">{item.summary}</p>
              <div class="mt-7 border-t border-slate-200 pt-5">
                <p class="text-xs font-bold uppercase tracking-[0.16em] text-slate-400">包含模块</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {item.modules.slice(0, 3).map((moduleName) => (
                    <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-600 ring-1 ring-slate-200">{moduleName}</span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
