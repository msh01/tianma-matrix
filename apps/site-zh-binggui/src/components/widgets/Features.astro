---
type Item = {
  title: string;
  description: string;
  icon: string;
};

export interface Props {
  id?: string;
  tagline?: string;
  title: string;
  subtitle?: string;
  items: Item[];
}

const { id, tagline, title, subtitle, items } = Astro.props;
---

<section id={id} class="bg-slate-50 py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">
    <div class="mx-auto max-w-3xl text-center">
      {tagline && <p class="text-sm font-bold uppercase tracking-[0.18em] text-cyan-700">{tagline}</p>}
      <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-slate-950 md:text-4xl">{title}</h2>
      {subtitle && <p class="mt-5 text-lg leading-8 text-slate-600">{subtitle}</p>}
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {items.map((item) => (
        <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-soft">
          <div class="grid h-11 w-11 place-items-center rounded-xl bg-cyan-50 text-xl">{item.icon}</div>
          <h3 class="mt-5 text-lg font-bold text-slate-950">{item.title}</h3>
          <p class="mt-3 text-sm leading-7 text-slate-600">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
