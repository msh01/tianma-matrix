---
export interface Props {
  id?: string;
}

const { id } = Astro.props;
---

<section id={id} class="bg-white py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="overflow-hidden rounded-[2rem] bg-slate-950 px-6 py-12 text-center text-white shadow-soft sm:px-12">
      <p class="text-sm font-bold uppercase tracking-[0.18em] text-cyan-300">Start a project</p>
      <h2 class="mx-auto mt-4 max-w-3xl text-3xl font-extrabold tracking-tight md:text-5xl">
        <slot name="title" />
      </h2>
      <p class="mx-auto mt-5 max-w-2xl leading-8 text-slate-300">
        <slot name="subtitle" />
      </p>
      <div class="mt-8">
        <slot name="actions" />
      </div>
    </div>
  </div>
</section>
