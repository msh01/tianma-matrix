---
type Item = {
  title: string;
  description: string;
};

export interface Props {
  id?: string;
  title: string;
  subtitle?: string;
  items: Item[];
}

const { id, title, subtitle, items } = Astro.props;
---

<section id={id} class="bg-slate-950 py-20 text-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">
    <div class="max-w-3xl">
      <p class="text-sm font-bold uppercase tracking-[0.18em] text-cyan-300">Delivery Process</p>
      <h2 class="mt-3 text-3xl font-extrabold tracking-tight md:text-4xl">{title}</h2>
      {subtitle && <p class="mt-5 text-lg leading-8 text-slate-300">{subtitle}</p>}
    </div>

    <div class="mt-12 grid gap-5 md:grid-cols-5">
      {items.map((item, index) => (
        <article class="rounded-2xl border border-white/10 bg-white/5 p-5">
          <p class="text-sm font-bold text-cyan-300">0{index + 1}</p>
          <h3 class="mt-5 font-bold">{item.title}</h3>
          <p class="mt-3 text-sm leading-6 text-slate-300">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
