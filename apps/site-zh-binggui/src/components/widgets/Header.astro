---
import { siteConfig } from "../../site.config";

type Link = {
  text: string;
  href: string;
};

export interface Props {
  links?: Link[];
  actions?: Link[];
}

const { links = [], actions = [] } = Astro.props;
---

<header class="sticky top-0 z-40 border-b border-slate-200/70 bg-white/90 backdrop-blur">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6">
    <a class="flex items-center gap-3 text-slate-950" href="/">
      <span class="grid h-9 w-9 place-items-center rounded-xl bg-cyan-700 text-sm font-black text-white shadow-soft">冰</span>
      <span class="text-base font-bold tracking-tight">{siteConfig.name}</span>
    </a>

    <div class="hidden items-center gap-7 text-sm font-medium text-slate-600 md:flex">
      {links.map((link) => <a class="transition hover:text-cyan-700" href={link.href}>{link.text}</a>)}
    </div>

    <div class="flex items-center gap-2">
      {actions.map((action) => (
        <a class="rounded-full bg-slate-950 px-4 py-2 text-sm font-semibold text-white shadow-soft transition hover:bg-cyan-800" href={action.href}>
          {action.text}
        </a>
      ))}
    </div>
  </nav>
</header>
