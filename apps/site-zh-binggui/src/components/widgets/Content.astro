---
type Item = {
  title: string;
  description: string;
};

export interface Props {
  id?: string;
  tagline?: string;
  title: string;
  items: Item[];
  image: {
    src: string;
    alt: string;
  };
  isReversed?: boolean;
}

const { id, tagline, title, items, image, isReversed = false } = Astro.props;
---

<section id={id} class="relative overflow-hidden bg-white py-20">
  <div class="mx-auto grid max-w-7xl gap-12 px-4 sm:px-6 lg:grid-cols-2 lg:items-center">
    <div class={isReversed ? "lg:order-2" : ""}>
      {tagline && <p class="text-sm font-bold uppercase tracking-[0.18em] text-cyan-700">{tagline}</p>}
      <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-slate-950 md:text-4xl">{title}</h2>
      <div class="mt-8 grid gap-5">
        {items.map((item) => (
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
            <h3 class="font-bold text-slate-950">{item.title}</h3>
            <p class="mt-2 text-sm leading-7 text-slate-600">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
    <div class={isReversed ? "lg:order-1" : ""}>
      <img class="aspect-[5/4] w-full rounded-[1.75rem] object-cover shadow-soft" src={image.src} alt={image.alt} loading="lazy" />
    </div>
  </div>
</section>
