{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@tianma/ui-components/*": ["packages/ui-components/src/*"],
      "@tianma/google-ads/*": ["packages/google-ads/src/*"],
      "@tianma/scraper-utils": ["packages/scraper-utils/src/index.ts"]
    }
  }
}
