---
import AdSense from "@tianma/google-ads/AdSense.astro";
import GoogleAnalytics from "@tianma/google-ads/GoogleAnalytics.astro";

type NavItem = {
  label: string;
  href: string;
};

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  lang?: "zh-CN" | "en";
  siteName: string;
  tagline?: string;
  navItems?: NavItem[];
  enableAds?: boolean;
  adsenseClientId?: string;
  adsenseSlot?: string;
  gaMeasurementId?: string;
}

const {
  title,
  description,
  canonical,
  lang = "zh-CN",
  siteName,
  tagline,
  navItems = [{ label: "Home", href: "/" }],
  enableAds = false,
  adsenseClientId,
  adsenseSlot,
  gaMeasurementId
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    {enableAds && <GoogleAnalytics measurementId={gaMeasurementId} />}
  </head>
  <body class="min-h-screen bg-white font-sans text-zinc-950 antialiased">
    <header class="mx-auto flex max-w-3xl items-center justify-between px-5 py-8">
      <a class="text-lg font-bold tracking-tight" href="/">{siteName}</a>
      <nav class="flex gap-5 text-sm text-zinc-600">
        {navItems.map((item) => <a class="transition hover:text-zinc-950" href={item.href}>{item.label}</a>)}
      </nav>
    </header>

    <main class="mx-auto max-w-3xl px-5 pb-16">
      {
        tagline && (
          <p class="mb-10 max-w-2xl border-b border-zinc-200 pb-8 text-lg leading-8 text-zinc-600">
            {tagline}
          </p>
        )
      }
      <slot />
      {enableAds && <AdSense clientId={adsenseClientId} slot={adsenseSlot} class="mt-12" />}
    </main>

    <footer class="mx-auto max-w-3xl border-t border-zinc-200 px-5 py-8 text-sm text-zinc-500">
      © {new Date().getFullYear()} {siteName}
    </footer>
  </body>
</html>
