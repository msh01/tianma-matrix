---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  siteName?: string;
}

const {
  title,
  description,
  canonical,
  siteName = "天马 IT 技术笔记"
} = Astro.props;

const navItems = [
  { label: "首页", href: "/" },
  { label: "文章", href: "/" },
  { label: "分类", href: "/categories/" },
  { label: "搜索", href: "/search/" }
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-name" content="bookworm-light-astro-adapted" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
  </head>
  <body class="min-h-screen bg-white font-sans text-[#747577] antialiased">
    <header class="pt-6">
      <nav class="mx-auto flex max-w-6xl flex-wrap items-center justify-between px-5">
        <a class="text-2xl font-bold tracking-tight text-[#152035]" href="/">
          {siteName}
        </a>
        <input id="bookworm-nav-toggle" type="checkbox" class="peer hidden" />
        <label
          for="bookworm-nav-toggle"
          class="cursor-pointer rounded border border-[#D5D5D5] px-3 py-2 text-sm font-semibold text-[#152035] md:hidden"
        >
          Menu
        </label>
        <div class="hidden w-full items-center justify-between gap-8 pt-6 peer-checked:flex md:flex md:w-auto md:pt-0">
          <ul class="flex flex-col gap-4 md:flex-row md:items-center md:gap-8">
            {navItems.map((item) => (
              <li>
                <a class="font-semibold text-[#152035] transition hover:text-[#01AD9F]" href={item.href}>
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </nav>
    </header>

    <main class="min-h-[60vh]">
      <slot />
    </main>

    <footer class="mt-20 border-t border-[#D5D5D5]">
      <div class="mx-auto grid max-w-6xl gap-8 px-5 py-10 md:grid-cols-[1.4fr_0.8fr]">
        <div>
          <p class="text-xl font-bold text-[#152035]">{siteName}</p>
          <p class="mt-3 max-w-xl leading-7">
            干净的中文技术博客，专注软件开发、前端架构、构建系统和内容站工程化。
          </p>
        </div>
        <div class="md:text-right">
          <p class="font-semibold text-[#152035]">Bookworm Light Astro Adaptation</p>
          <p class="mt-2 text-sm">Theme style inspired by Themefisher Bookworm Light.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
